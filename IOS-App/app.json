{
  "expo": {
    "name": "Apollova",
    "slug": "apollova-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "apollova",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.apollova.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Apollova needs camera access to scan the QR code displayed on your PC for pairing."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Apollova needs camera access to scan the QR code displayed on your PC for pairing."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
